---
/**
 * Head override — single source of truth for all per-page JSON-LD.
 *
 * Replaces the default Starlight Head component and adds:
 *  1. All default <head> entries (title, meta, canonical, OG, etc.)
 *  2. WebPage / TechArticle schema (every page)
 *  3. BreadcrumbList schema (every page)
 *  4. FAQPage schema (FAQ pages only — parsed from raw markdown at build time)
 *  5. HowTo schema (HowTo pages only — parsed from raw markdown at build time)
 */
import fs from 'node:fs';
import {
  buildWebPageSchema,
  buildBreadcrumbSchema,
  buildFAQSchema,
  buildHowToSchema,
  extractFAQsFromMarkdown,
  extractStepsFromMarkdown,
  FAQ_PAGES,
  HOWTO_PAGES,
} from '../utils/structured-data';

const route = Astro.locals.starlightRoute;
const { head } = route;

// Derive page metadata
const origin = (Astro.site?.href ?? 'https://mezo.org/docs').replace(/\/$/, '');
const siteOrigin = new URL(origin).origin; // https://mezo.org
const pageUrl = siteOrigin + Astro.url.pathname;
const pageTitle = route.entry.data.title ?? 'Mezo Documentation';
const defaultDesc =
  'Official Mezo documentation: Wallet setup, asset bridging, MUSD borrowing guides, and developer resources.';
const pageDescription = route.entry.data.description ?? defaultDesc;

// Page ID — normalised to lowercase for FAQ lookup
const pageId = route.id;
const pageIdLower = pageId.toLowerCase();

// Build schemas
const webPageSchema = buildWebPageSchema(pageTitle, pageDescription, pageUrl);
const breadcrumbSchema = buildBreadcrumbSchema(
  Astro.url.pathname,
  pageTitle,
  siteOrigin
);

// Conditionally build FAQ schema
let faqSchema: ReturnType<typeof buildFAQSchema> | null = null;
const faqConfig = FAQ_PAGES[pageIdLower] ?? FAQ_PAGES[pageId];
if (faqConfig) {
  let body: string | undefined;
  // Try entry.body first (Astro content collection field)
  try {
    body = (route.entry as any).body;
  } catch {
    // noop
  }
  // Fallback: read from filesystem
  if (!body && route.entry.filePath) {
    try {
      const raw = fs.readFileSync(route.entry.filePath, 'utf-8');
      // Strip frontmatter
      const fmEnd = raw.indexOf('---', raw.indexOf('---') + 3);
      body = fmEnd !== -1 ? raw.slice(fmEnd + 3) : raw;
    } catch {
      // noop
    }
  }
  if (body) {
    const questions = extractFAQsFromMarkdown(body, faqConfig.format);
    if (questions.length) {
      faqSchema = buildFAQSchema(pageUrl, questions);
    }
  }
}

// Conditionally build HowTo schema
let howToSchema: ReturnType<typeof buildHowToSchema> | null = null;
const howToConfig = HOWTO_PAGES[pageIdLower] ?? HOWTO_PAGES[pageId];
if (howToConfig) {
  let body: string | undefined;
  try {
    body = (route.entry as any).body;
  } catch {
    // noop
  }
  if (!body && route.entry.filePath) {
    try {
      const raw = fs.readFileSync(route.entry.filePath, 'utf-8');
      const fmEnd = raw.indexOf('---', raw.indexOf('---') + 3);
      body = fmEnd !== -1 ? raw.slice(fmEnd + 3) : raw;
    } catch {
      // noop
    }
  }
  if (body) {
    const steps = extractStepsFromMarkdown(body);
    if (steps.length >= 2) {
      howToSchema = buildHowToSchema(pageUrl, howToConfig.name, steps);
    }
  }
}
---

{/*
  Re-render all default Starlight head entries (title, meta, OG, canonical, etc.).
  This includes the Organization and WebSite JSON-LD schemas configured in astro.config.mjs.
*/}
{head.map(({ tag: Tag, attrs, content }) => <Tag {...attrs} set:html={content} />)}

{/* WebPage / TechArticle — every page */}
<script type="application/ld+json" set:html={JSON.stringify(webPageSchema)} />

{/* BreadcrumbList — every page */}
{breadcrumbSchema && (
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
)}

{/* FAQPage — FAQ pages only */}
{faqSchema && (
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
)}

{/* HowTo — HowTo pages only */}
{howToSchema && (
  <script type="application/ld+json" set:html={JSON.stringify(howToSchema)} />
)}
