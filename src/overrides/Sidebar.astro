---
import type { Props } from '@astrojs/starlight/props';
import Default from '@astrojs/starlight/components/Sidebar.astro';

import StarlightSidebarTopicsSidebar from '../components/starlight/Sidebar.astro';

const currentBase = Astro.url.pathname.split('/').slice(0, 3).join('/');
const sidebar = Array.isArray(Astro.props.sidebar) ? Astro.props.sidebar : [];

const filteredSidebar = sidebar.filter(
  (entry) =>
    entry.type === 'group' &&
    entry.entries.some((subEntry) => subEntry.type === 'link' && subEntry.href.startsWith(currentBase))
);

const sidebarProps: Props = {
  ...Astro.props,
  sidebar: filteredSidebar,
};
---

<StarlightSidebarTopicsSidebar />
<Default {...sidebarProps}><slot /></Default>
